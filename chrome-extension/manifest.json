{
  "manifest_version": 3,
  "name": "CVs-Optimizador",
  "version": "1.0.0",
  "description": "Guarda vacantes de LinkedIn directamente en CVs-Optimizador",

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "action": {
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "CVs-Optimizador"
  },

  "side_panel": {
    "default_path": "popup.html"
  },

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/jobs/view/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "sidePanel"
  ],

  "host_permissions": [
    "https://www.linkedin.com/jobs/view/*",
    "http://localhost:8001/*"
  ]
}
